# Copy this file to .env.local and fill in the values.
# Never commit .env.local to version control.

# A random string of at least 32 characters used to sign JWT session tokens.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change-me-to-a-32-char-minimum-random-string

# WebAuthn Relying Party settings.
# For local development keep these as shown.
# For production set RP_ID to your domain (e.g. myapp.railway.app)
# and RP_ORIGIN to your full origin (e.g. https://myapp.railway.app).
RP_NAME=Todo App
RP_ID=localhost
RP_ORIGIN=http://localhost:3000
